def fibonacci(n):
    a, b = 0, 1
    series = []
    for _ in range(n):
        series.append(a)
        a, b = b, a + b
    return series

num = int(input("Enter how many terms you want: "))

if num <= 0:
    print("Please enter a positive integer.")
else:
    print(f"Fibonacci series with {num} terms: {fibonacci(num)}")
